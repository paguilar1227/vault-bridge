{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "keyVaultName": {
      "type": "string",
      "defaultValue": "pablo-secrets",
      "metadata": {
        "description": "Globally unique Key Vault name."
      }
    },
    "containerAppName": {
      "type": "string",
      "defaultValue": "vault-bridge"
    },
    "containerAppEnvName": {
      "type": "string",
      "defaultValue": "vault-bridge-env"
    },
    "sharedResourceGroup": {
      "type": "string",
      "defaultValue": "pablo-rg",
      "metadata": {
        "description": "Resource group containing the shared ACR."
      }
    },
    "registryName": {
      "type": "string",
      "defaultValue": "pabloregistry"
    },
    "imageName": {
      "type": "string",
      "defaultValue": "vault-bridge"
    },
    "imageTag": {
      "type": "string",
      "defaultValue": "latest"
    },
    "vaultBridgeToken": {
      "type": "securestring",
      "metadata": {
        "description": "Bearer token for MCP connection auth. Generate with: openssl rand -hex 32"
      }
    }
  },
  "variables": {
    "registryLoginServer": "[concat(parameters('registryName'), '.azurecr.io')]",
    "containerImage": "[concat(variables('registryLoginServer'), '/', parameters('imageName'), ':', parameters('imageTag'))]",
    "acrResourceId": "[resourceId(parameters('sharedResourceGroup'), 'Microsoft.ContainerRegistry/registries', parameters('registryName'))]",
    "kvSecretsUserRoleId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '4633458b-17de-408a-b874-0445c86b69e6')]",
    "acrPullRoleId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '7f951dda-4ed3-4680-a7ca-43fe172d538d')]"
  },
  "resources": [
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-07-01",
      "name": "[parameters('keyVaultName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "family": "A",
          "name": "standard"
        },
        "tenantId": "[subscription().tenantId]",
        "enableRbacAuthorization": true,
        "enableSoftDelete": true,
        "softDeleteRetentionInDays": 7
      }
    },
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2024-03-01",
      "name": "[parameters('containerAppEnvName')]",
      "location": "[parameters('location')]",
      "properties": {
        "zoneRedundant": false
      }
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[parameters('containerAppName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppEnvName'))]"
      ],
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppEnvName'))]",
        "configuration": {
          "secrets": [
            {
              "name": "vault-bridge-token",
              "value": "[parameters('vaultBridgeToken')]"
            }
          ],
          "ingress": {
            "external": true,
            "targetPort": 8080,
            "transport": "http"
          },
          "registries": [
            {
              "server": "[variables('registryLoginServer')]",
              "identity": "system"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "vault-bridge",
              "image": "[variables('containerImage')]",
              "resources": {
                "cpu": 0.25,
                "memory": "0.5Gi"
              },
              "env": [
                {
                  "name": "AZURE_VAULT_URL",
                  "value": "[concat('https://', parameters('keyVaultName'), '.vault.azure.net')]"
                },
                {
                  "name": "VAULT_BRIDGE_TOKEN",
                  "secretRef": "vault-bridge-token"
                },
                {
                  "name": "ENVIRONMENT",
                  "value": "production"
                }
              ]
            }
          ],
          "scale": {
            "minReplicas": 0,
            "maxReplicas": 1
          }
        }
      }
    },
    {
      "comments": "Grant Container App's managed identity 'Key Vault Secrets User' on the Key Vault",
      "type": "Microsoft.KeyVault/vaults/providers/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[concat(parameters('keyVaultName'), '/Microsoft.Authorization/', guid(resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName')), variables('kvSecretsUserRoleId'), resourceId('Microsoft.App/containerApps', parameters('containerAppName'))))]",
      "dependsOn": [
        "[resourceId('Microsoft.App/containerApps', parameters('containerAppName'))]",
        "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]"
      ],
      "properties": {
        "roleDefinitionId": "[variables('kvSecretsUserRoleId')]",
        "principalId": "[reference(resourceId('Microsoft.App/containerApps', parameters('containerAppName')), '2024-03-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal"
      }
    },
    {
      "comments": "Grant Container App's managed identity 'AcrPull' on the shared ACR (cross-resource-group)",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2022-09-01",
      "name": "acrPullRoleAssignment",
      "resourceGroup": "[parameters('sharedResourceGroup')]",
      "dependsOn": [
        "[resourceId('Microsoft.App/containerApps', parameters('containerAppName'))]"
      ],
      "properties": {
        "mode": "Incremental",
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "resources": [
            {
              "type": "Microsoft.ContainerRegistry/registries/providers/roleAssignments",
              "apiVersion": "2022-04-01",
              "name": "[concat(parameters('registryName'), '/Microsoft.Authorization/', guid(variables('acrResourceId'), variables('acrPullRoleId'), resourceId('Microsoft.App/containerApps', parameters('containerAppName'))))]",
              "properties": {
                "roleDefinitionId": "[variables('acrPullRoleId')]",
                "principalId": "[reference(resourceId('Microsoft.App/containerApps', parameters('containerAppName')), '2024-03-01', 'Full').identity.principalId]",
                "principalType": "ServicePrincipal"
              }
            }
          ]
        }
      }
    }
  ],
  "outputs": {
    "appUrl": {
      "type": "string",
      "value": "[concat('https://', reference(resourceId('Microsoft.App/containerApps', parameters('containerAppName'))).configuration.ingress.fqdn)]"
    },
    "mcpEndpoint": {
      "type": "string",
      "value": "[concat('https://', reference(resourceId('Microsoft.App/containerApps', parameters('containerAppName'))).configuration.ingress.fqdn, '/sse')]"
    },
    "principalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.App/containerApps', parameters('containerAppName')), '2024-03-01', 'Full').identity.principalId]"
    }
  }
}
